{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rosie",
  "compatibility_date": "2026-04-08",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "rosie.astro.build",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
