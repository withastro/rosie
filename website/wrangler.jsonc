{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rosie-website",
  "compatibility_date": "2026-04-08",
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "rosie.libs.technology",
      "custom_domain": true
    }
  ],
  "observability": {
    "enabled": true
  }
}
